# Configuración del servidor
PORT=3001

# Conexión a MongoDB
# Para Docker local:
MONGODB_URI=mongodb://mongodb:27017/portfolio
# Para MongoDB Atlas (nube):
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/portfolio

# Configuración de Email (Gmail)
# Para usar Gmail, necesitas crear una "Contraseña de aplicación":
# 1. Ve a https://myaccount.google.com/security
# 2. Activa la verificación en 2 pasos si no la tienes
# 3. Ve a "Contraseñas de aplicaciones" y genera una nueva
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=aitormon@gmail.com

# Frontend URL para CORS
FRONTEND_URL=https://aitor-montalban-portfolio.up.railway.app/
